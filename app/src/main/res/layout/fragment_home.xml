<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/homeTitle"
        android:text="@string/home_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/statusIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:layout_constraintTop_toBottomOf="@id/homeTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/statusText"
        android:text="未连接"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBaseline_toBaselineOf="@id/statusIcon"
        app:layout_constraintStart_toEndOf="@id/statusIcon"
        android:layout_marginStart="8dp"/>

    <TextView
        android:id="@+id/ipText"
        android:text="IP地址 -"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/statusIcon"
        app:layout_constraintStart_toStartOf="@id/statusIcon"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/accountText"
        android:text="登录账号 -"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/ipText"
        app:layout_constraintStart_toStartOf="@id/ipText"
        app:layout_constraintEnd_toEndOf="@id/ipText"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/reconnectButton"
        android:text="@string/reconnect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/accountText"
        app:layout_constraintStart_toStartOf="@id/accountText"
        app:layout_constraintEnd_toEndOf="@id/accountText"
        android:layout_marginTop="16dp"/>

    <LinearLayout
        android:id="@+id/entryRow"
        android:orientation="horizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/reconnectButton"
        app:layout_constraintStart_toStartOf="@id/reconnectButton"
        app:layout_constraintEnd_toEndOf="@id/reconnectButton"
        android:layout_marginTop="24dp">

        <Button
            android:id="@+id/accountEntry"
            android:text="@string/account_manage"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/settingsEntry"
            android:text="@string/settings"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
